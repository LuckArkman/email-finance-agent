# Email Finance Agent Configuration
# Rename this file to .env and fill in the values

# AI & LLM
OPENAI_API_KEY=sk-xxxx
SENTRY_DSN=

# AWS Infrastructure
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=finance-agent-documents

# Databases
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/finance_agent
MONGO_URL=mongodb://mongodb:27017
REDIS_URL=redis://redis:6379/0

# Security
JWT_SECRET_KEY=change_this_to_a_long_random_string_in_production
